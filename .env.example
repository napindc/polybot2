DISCORD_BOT_TOKEN=your_discord_bot_token_here
DISCORD_CLIENT_ID=your_discord_client_id
DISCORD_GUILD_ID=your_discord_guild_id

GEMINI_API_KEY=your_primary_gemini_api_key_here
GEMINI_API_KEY_2=your_optional_second_gemini_api_key_here
GEMINI_API_KEY_3=your_optional_third_gemini_api_key_here
# Add more keys as GEMINI_API_KEY_4, _5, _6, etc.

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_anon_key_here

AUTH_BASE_URL=http://localhost:3001

# Polymarket CLOB API credentials
POLYMARKET_API_KEY=your_polymarket_api_key
POLYMARKET_API_SECRET=your_polymarket_api_secret
POLYMARKET_PASSPHRASE=your_polymarket_passphrase
WALLET_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE
POLYMARKET_PROXY_WALLET=0xYOUR_PROXY_WALLET_ADDRESS
# Optional: one of EOA | POLY_PROXY | POLY_GNOSIS_SAFE (or 0/1/2). Default is POLY_PROXY.
POLYMARKET_SIGNATURE_TYPE=POLY_PROXY

# Optional: restrict CORS origins (comma-separated)
# CORS_ORIGINS=http://localhost:3001,https://yourdomain.com

# Optional: shared secret to protect auth server endpoints
# BOT_API_SECRET=your_random_secret_here

# Optional: custom Polygon RPC URL
# POLYGON_RPC_URL=https://your-rpc-endpoint.com

# Optional: automatically redeem settled winning positions
# Set to false to disable
# AUTO_REDEEM_ENABLED=true
# Sweep interval in milliseconds
# AUTO_REDEEM_INTERVAL_MS=180000
# Max redeem tx attempts per sweep
# AUTO_REDEEM_MAX_PER_SWEEP=6
# Ignore tiny dust positions below this size
# AUTO_REDEEM_MIN_SIZE=0.01
# Minimum native gas balance (wei) needed before redeem tx attempts
# AUTO_REDEEM_MIN_GAS_WEI=1000000000000000
# Allow redeem attempts when signer wallet differs from proxy wallet
# AUTO_REDEEM_ALLOW_PROXY_SIGNER_MISMATCH=false
# Override contract addresses if needed
# POLYMARKET_CONDITIONAL_TOKENS_ADDRESS=0x4D97DCd97eC945f40cF65F87097ACe5EA0476045
# POLYMARKET_COLLATERAL_TOKEN=0x2791Bca1f2de4661ED88A30C99A7a9449Aa84174
# Optional: execute proxy-wallet redemption automatically when proxy holds redeemables
# AUTO_REDEEM_PROXY_ENABLED=true

# Optional: Redis URL for persistent spend tracking (falls back to in-memory if not set)
# REDIS_URL=redis://localhost:6379

# Optional: Owner Discord user ID — exempt from $5/day spend limit (for testing)
# OWNER_DISCORD_ID=your_discord_user_id
